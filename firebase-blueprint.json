{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Metadata for authenticated users",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "subscription_status": { "type": "string", "enum": ["active", "inactive"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Course": {
      "title": "Course",
      "description": "Educational course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "teacherId": { "type": "string" }
      },
      "required": ["title", "subject"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "A lesson within a course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "videoUrl": { "type": "string" },
        "orderIndex": { "type": "number" },
        "courseId": { "type": "string" }
      },
      "required": ["title", "courseId"]
    },
    "Task": {
      "title": "Task",
      "description": "A question/task within a lesson",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "image_url": { "type": "string" },
        "optionA": { "type": "string" },
        "optionB": { "type": "string" },
        "optionC": { "type": "string" },
        "optionD": { "type": "string" },
        "correctAnswer": { "type": "string", "enum": ["A", "B", "C", "D"] },
        "explanation": { "type": "string" }
      },
      "required": ["question", "optionA", "optionB", "optionC", "optionD", "correctAnswer"]
    },
    "Result": {
      "title": "Result",
      "description": "User test results",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "lesson_id": { "type": "string" },
        "course_id": { "type": "string" },
        "score": { "type": "number" },
        "total_questions": { "type": "number" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "lesson_id", "score", "total_questions"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription details",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "plan": { "type": "string", "enum": ["basic", "test", "premium"] },
        "price": { "type": "number" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "exams_left": { "type": "number" },
        "has_video_access": { "type": "boolean" },
        "has_ai_chat": { "type": "boolean" }
      },
      "required": ["user_id", "plan", "start_date", "end_date"]
    },
    "TeacherApplication": {
      "title": "Teacher Application",
      "description": "Application submitted by a potential teacher",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "name": { "type": "string" },
        "education": { "type": "string" },
        "experience": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "applied_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "name", "education", "experience", "phone", "subject", "status"]
    },
    "Exam": {
      "title": "Weekly Exam",
      "description": "A comprehensive weekly exam created by a teacher",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "teacher_id": { "type": "string" },
        "questions_count": { "type": "number" },
        "duration_minutes": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "teacher_id", "questions_count", "duration_minutes"]
    },
    "ExamResult": {
      "title": "Exam Result",
      "description": "Result of a student taking an exam",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "exam_id": { "type": "string" },
        "score": { "type": "number" },
        "total_questions": { "type": "number" },
        "completed_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "exam_id", "score", "total_questions", "completed_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/subscription/current": {
      "schema": "Subscription",
      "description": "Active subscription for the user"
    },
    "/teacher_applications/{applicationId}": {
      "schema": "TeacherApplication",
      "description": "Teacher job applications"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Courses"
    },
    "/courses/{courseId}/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Lessons in a course"
    },
    "/courses/{courseId}/lessons/{lessonId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks in a lesson"
    },
    "/exams/{examId}": {
      "schema": "Exam",
      "description": "Weekly exams"
    },
    "/exams/{examId}/questions/{questionId}": {
      "schema": "Task",
      "description": "Questions within an exam"
    },
    "/exam_results/{resultId}": {
      "schema": "ExamResult",
      "description": "Results for weekly exams"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Global test results"
    }
  }
}
