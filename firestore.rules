rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Admin check: Requires an entry in /admins/{uid} or matching email
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.get('email', '').lower() == 'jarves276@gmail.com') ||
        (request.auth.uid == 'PgAHmtZI71S98LI7KfrTWjURSU53') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    function isTeacher() {
      // Safer check for teacher role using get() wrapper
      return isSignedIn() && (
        isAdmin() || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'teacher')
      );
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'subscription_status', 'created_at'])
          && data.keys().size() >= 5
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.email is string && data.email.size() > 0 && data.email.size() <= 100
          && data.role in ['admin', 'teacher', 'student']
          && data.subscription_status in ['active', 'inactive'];
    }

    function isValidTeacherApplication(data) {
       return data.keys().hasAll(['user_id', 'name', 'education', 'experience', 'phone', 'subject', 'status', 'applied_at'])
          && data.keys().size() == 8
          && data.user_id == request.auth.uid
          && data.status == 'pending';
    }

    function isValidCourse(data) {
      return data.keys().hasAll(['title', 'description', 'subject', 'teacher_id'])
          && data.keys().size() >= 4 
          && data.title is string && data.title.size() <= 200
          && data.description is string && data.description.size() <= 2000
          && data.subject is string && data.subject.size() <= 100
          && data.teacher_id == request.auth.uid;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'video_url', 'order_index', 'course_id'])
          && data.keys().size() >= 4
          && data.title is string && data.title.size() <= 200
          && data.video_url is string && data.video_url.size() <= 500
          && data.order_index is number;
    }

    function isValidTask(data) {
      let baseKeys = ['question', 'explanation', 'type', 'correct_answer'];
      return data.keys().hasAll(baseKeys)
          && data.question is string && data.question.size() <= 1000
          && data.explanation is string && data.explanation.size() <= 2000
          && data.type in ['choice', 'open', 'multi_choice']
          && (!data.keys().contains('image_url') || (data.image_url is string && data.image_url.size() <= 1000))
          && (
            (data.type == 'choice' && 
             data.keys().hasAll(['option_a', 'option_b', 'option_c', 'option_d']) && 
             data.keys().size() >= 8 &&
             data.correct_answer in ['A', 'B', 'C', 'D']) ||
            (data.type == 'multi_choice' && 
             data.keys().hasAll(['option_a', 'option_b', 'option_c', 'option_d']) && 
             data.keys().size() >= 8 &&
             data.correct_answer is string) ||
            (data.type == 'open' && 
             data.keys().size() >= 4 && 
             data.correct_answer is string)
          );
    }

    function isValidResult(data) {
      return data.keys().hasAll(['user_id', 'lesson_id', 'course_id', 'score', 'total_questions', 'completed_at'])
          && data.keys().size() == 6
          && data.user_id == request.auth.uid
          && data.score is number && data.score >= 0
          && data.total_questions is number && data.total_questions > 0
          && (data.completed_at == request.time || data.completed_at is string);
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['user_id', 'plan', 'price', 'start_date', 'end_date', 'exams_left', 'has_video_access', 'has_ai_chat'])
          && data.keys().size() == 8
          && data.user_id == request.auth.uid
          && data.plan in ['basic', 'test', 'premium']
          && data.exams_left is number && data.exams_left >= 0;
    }

    // --- Match Blocks ---

    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name'])) ||
        (isAdmin())
      );
    }

    match /users/{userId}/subscription/{docId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /teacher_applications/{applicationId} {
      allow get: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTeacherApplication(incoming());
      allow update: if isAdmin();
    }

    match /courses/{courseId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if (isAdmin() || isTeacher()) && isValidCourse(incoming());
      allow update, delete: if isAdmin() || (isTeacher() && existing().teacher_id == request.auth.uid);

      match /lessons/{lessonId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create, update, delete: if isAdmin() || isTeacher();

        match /tasks/{taskId} {
          allow get: if isSignedIn();
          allow list: if isSignedIn();
          allow create, update, delete: if isAdmin() || isTeacher();
        }
      }
    }

    match /results/{resultId} {
      allow get: if isSignedIn() && (existing().user_id == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.user_id == request.auth.uid || isAdmin() || isTeacher());
      allow create: if isSignedIn() && isValidResult(incoming());
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (resource.data.participants.hasAny([request.auth.uid]) || isAdmin());
      allow list: if isSignedIn() && (
        resource.data.participants.hasAny([request.auth.uid]) || 
        isAdmin() ||
        (isTeacher() && resource.data.subject == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subject)
      );
      allow create: if isSignedIn();
    }
  }
}
